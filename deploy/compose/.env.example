# OAuth2 resource server configuration (API container).
DOCROOT_API_OAUTH_JWKS_URL=https://your-idp/.well-known/jwks.json
DOCROOT_API_OAUTH_AUDIENCE=your-api-audience
# Role extractor: keycloak (default)
DOCROOT_API_OAUTH_ROLE_EXTRACTOR=keycloak
# CORS allowed origins (comma-separated, or * for all)
DOCROOT_API_CORS_ORIGINS=*
# Set to true on HTTPS deployments.
DOCROOT_API_COOKIE_SECURE=false

# OIDC public client config for the nginx/frontend container.
# Written to /oidc-config.json at container startup.
# Leave empty to disable the OIDC login button.
DOCROOT_WEB_OIDC_ISSUER=https://your-idp/realms/your-realm
DOCROOT_WEB_OIDC_CLIENT_ID=docroot-ui
