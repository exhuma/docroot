# OAuth2 resource server configuration.
DOCROOT_OAUTH_JWKS_URL=https://your-idp/.well-known/jwks.json
DOCROOT_OAUTH_AUDIENCE=your-api-audience
# Role extractor: keycloak (default)
DOCROOT_OAUTH_ROLE_EXTRACTOR=keycloak
# CORS allowed origins (comma-separated, or * for all)
DOCROOT_CORS_ORIGINS=*
# Set to true on HTTPS deployments.
DOCROOT_COOKIE_SECURE=false

# OIDC public client config for the nginx/frontend container.
# Written to /oidc-config.json at container startup.
# Leave empty to disable the OIDC login button.
OIDC_ISSUER=https://your-idp/realms/your-realm
OIDC_CLIENT_ID=docroot-ui
